{
  "name": "@kronos/api",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "deploy": "wrangler deploy --minify src/index.ts",
    "typecheck": "tsgo",
    "test": "vitest",
    "lint": "oxlint --type-aware --deny-warnings .",
    "format": "oxfmt . '!worker-configuration.d.ts'",
    "format:check": "oxfmt --check . '!worker-configuration.d.ts'"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@kronos/common": "^1.0.0",
    "@types/luxon": "^3.7.1",
    "hono": "^4.12.15",
    "hyparquet": "^1.25.6",
    "hyparquet-compressors": "^1.1.1",
    "luxon": "^3.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.0",
    "wrangler": "^4.85.0"
  }
}
