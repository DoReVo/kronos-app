{
  "name": "@kronos/web",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsgo && vite build",
    "typecheck": "tsgo",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "oxlint --type-aware --deny-warnings .",
