    "@uidotdev/usehooks": "^2.4.1",
    "idb-keyval": "^6.2.2",
    "jotai": "^2.19.1",
    "ky": "^2.0.2",
    "luxon": "^3.7.2",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-aria": "^3.48.0",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1"
