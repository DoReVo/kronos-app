{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "sourceMap": true,
    "outDir": "dist",
    "removeComments": true,
    "verbatimModuleSyntax": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"],
  "ts-node": {
    "swc": true,
    "esm": true
  }
}
